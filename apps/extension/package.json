{
  "name": "code-vibe-reading-extension",
  "displayName": "Code Vibe Reading",
  "description": "Navigation-first code comprehension workbench for VS Code.",
  "version": "0.1.0",
  "private": true,
  "publisher": "local",
  "engines": {
    "vscode": "^1.97.0"
  },
  "categories": ["Other"],
  "activationEvents": [
    "onStartupFinished"
  ],
  "enabledApiProposals": [
    "editorInsets"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "vibe",
          "title": "Vibe",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "vibe": [
        {
          "id": "vibe.map",
          "name": "Map",
          "icon": "media/icon.svg"
        },
        {
          "id": "vibe.threads",
          "name": "Threads",
          "icon": "media/icon.svg",
          "type": "webview"
        },
        {
          "id": "vibe.cards",
          "name": "Cards",
          "icon": "media/icon.svg"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "vibe.map",
        "contents": "Build a local code map to inspect files, symbols, and traces.\n[Refresh Index](command:vibe.refreshIndex)"
      },
      {
        "view": "vibe.threads",
        "contents": "Ask grounded questions about code selections and keep the answers here.\n[Configure API](command:vibe.configureModel)\n[Ask About Selection](command:vibe.askAboutSelection)"
      },
      {
        "view": "vibe.cards",
        "contents": "Capture durable reading notes as cards.\n[Save Selection as Card](command:vibe.saveSelectionAsCard)\n[Open Canvas](command:vibe.openCanvas)"
      }
    ],
    "commands": [
      {
        "command": "vibe.refreshIndex",
        "title": "Vibe: Refresh Index",
        "icon": {
          "light": "media/refresh-light.svg",
          "dark": "media/refresh-dark.svg"
        }
      },
      {
        "command": "vibe.refreshIndexAndOverview",
        "title": "Vibe: Refresh Index and Generate Overview"
      },
      {
        "command": "vibe.testModelConnection",
        "title": "Vibe: Test Model Connection"
      },
      {
        "command": "vibe.configureModel",
        "title": "Vibe: Configure API"
      },
      {
        "command": "vibe.askAboutSelection",
        "title": "Vibe: Ask About Selection"
      },
      {
        "command": "vibe.explainCurrentSymbol",
        "title": "Vibe: Explain Current Symbol"
      },
      {
        "command": "vibe.saveSelectionAsCard",
        "title": "Vibe: Save Selection as Card"
      },
      {
        "command": "vibe.addThreadAnswerToCanvas",
        "title": "Vibe: Add Thread Answer to Canvas"
      },
      {
        "command": "vibe.deleteThread",
        "title": "Delete Thread"
      },
      {
        "command": "vibe.openCanvas",
        "title": "Vibe: Open Canvas"
      },
      {
        "command": "vibe.traceCallPath",
        "title": "Vibe: Trace Call Path"
      },
      {
        "command": "vibe.openThread",
        "title": "Vibe: Open Thread"
      },
      {
        "command": "vibe.openThreadFromCode",
        "title": "Vibe: Open Thread From Code"
      },
      {
        "command": "vibe.goToCodeFromThread",
        "title": "Vibe: Go To Code From Thread"
      },
      {
        "command": "vibe.openCard",
        "title": "Vibe: Open Card"
      },
      {
        "command": "vibe.openCitation",
        "title": "Vibe: Open Citation"
      },
      {
        "command": "vibe.openProjectOverview",
        "title": "Vibe: Open Project Overview"
      }
    ],
    "keybindings": [
      {
        "command": "vibe.askAboutSelection",
        "key": "ctrl+alt+q",
        "mac": "cmd+alt+q",
        "when": "editorTextFocus && editorHasSelection"
      },
      {
        "command": "vibe.deleteThread",
        "key": "delete",
        "mac": "backspace",
        "when": "focusedView == vibe.threads && listFocus && !inputFocus"
      },
      {
        "command": "vibe.goToCodeFromThread",
        "key": "ctrl+enter",
        "mac": "cmd+enter",
        "when": "focusedView == vibe.threads && listFocus && !inputFocus"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "vibe.askAboutSelection",
          "group": "navigation@1"
        },
        {
          "command": "vibe.saveSelectionAsCard",
          "group": "navigation@2"
        }
      ],
      "editor/title/context": [
        {
          "command": "vibe.explainCurrentSymbol",
          "group": "navigation@1"
        },
        {
          "command": "vibe.traceCallPath",
          "group": "navigation@2"
        }
      ],
      "view/title": [
        {
          "command": "vibe.refreshIndex",
          "when": "view == vibe.map",
          "group": "navigation@1"
        },
        {
          "command": "vibe.configureModel",
          "when": "view == vibe.threads",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "vibe.deleteThread",
          "when": "view == vibe.threads",
          "group": "inline"
        },
        {
          "command": "vibe.addThreadAnswerToCanvas",
          "when": "view == vibe.threads",
          "group": "navigation"
        },
        {
          "command": "vibe.goToCodeFromThread",
          "when": "view == vibe.threads && viewItem =~ /^thread\\.withCode/",
          "group": "inline"
        },
        {
          "command": "vibe.openCard",
          "when": "view == vibe.cards",
          "group": "inline"
        }
      ]
    },
    "configuration": {
      "title": "Code Vibe Reading",
      "properties": {
        "vibe.model.temperature": {
          "type": "number",
          "default": 0.1,
          "minimum": 0,
          "maximum": 2
        },
        "vibe.model.maxTokens": {
          "type": "number",
          "default": 8192,
          "minimum": 128,
          "maximum": 32768
        }
      }
    }
  },
  "dependencies": {
    "@code-vibe/analyzer": "workspace:*",
    "@code-vibe/model-gateway": "workspace:*",
    "@code-vibe/persistence": "workspace:*",
    "@code-vibe/retrieval": "workspace:*",
    "@code-vibe/shared": "workspace:*"
  },
  "scripts": {
    "watch": "node ../../scripts/build-extension.mjs --watch"
  }
}
