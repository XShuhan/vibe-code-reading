{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run Code Vibe Reading",
      "type": "extensionHost",
      "request": "launch",
      "preLaunchTask": "code-vibe: build",
      "args": [
        "--extensionDevelopmentPath=${workspaceFolder}/apps/extension",
        "${workspaceFolder}/~/Projects/code-vibe-testing/workspace"
      ],
      "outFiles": [
        "${workspaceFolder}/apps/extension/dist/**/*.js"
      ]
    }
  ]
}
